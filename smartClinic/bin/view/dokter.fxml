<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="controller.DokterController">

    <!-- TOP -->
    <top>

        <VBox spacing="10" styleClass="top-panel">

            <Label alignment="CENTER" maxWidth="Infinity" styleClass="title" text="SMART CLINIC" />

            <!-- TOOLBAR -->
              <HBox alignment="CENTER" spacing="15">

    <Button onAction="#handleTambahDokter" styleClass="btn-tambah" text="➕" />

    <Button onAction="#handleEditDokter" styleClass="btn-edit" text="✏" />

    <Button onAction="#handleHapusDokter" styleClass="btn-hapus" text="🗑" />

    <Button onAction="#loadDataDokter" styleClass="btn-refresh" text="🔄" />

    <TextField fx:id="txtCari" prefWidth="180" promptText="Cari dokter..." />

    <Button onAction="#handleCariDokter" styleClass="btn-cari" text="🔍" />

    <Button onAction="#handleCloseDokter" styleClass="btn-close" text="❌" />

</HBox>

        </VBox>

    </top>

    <!-- CENTER -->
 <center>

    <VBox spacing="15" styleClass="main-panel">

        <!-- TABLE -->
        <TableView fx:id="tableDokter" VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colId" prefWidth="82.0" text="ID" />

                <TableColumn fx:id="colNama" prefWidth="120.0" text="Nama" />

                <TableColumn fx:id="colSpesialis" prefWidth="160.0" text="Spesialis" />

                      <TableColumn fx:id="colHP" prefWidth="173.0" text="No HP" />

            </columns>

        </TableView>

    </VBox>

</center>

</BorderPane>
